# Sao chép thành `.env.local` (không commit). Drizzle Kit / `npm run db:studio` đọc file này.

CLOUDFLARE_ACCOUNT_ID=
# API Token: quyền đọc D1 (và migrate nếu dùng db:migrate). Tạo tại My Profile → API Tokens.
CLOUDFLARE_API_TOKEN=

# --- D1 preview (mặc định khi KHÔNG đặt ENVIRONMENT=production) ---
CLOUDFLARE_DATABASE_ID_PREVIEW=

# --- D1 production: chỉ khi ENVIRONMENT=production ---
# Phải trùng `database_id` (remote production) trong wrangler.json — KHÔNG dùng preview_database_id.
# ENVIRONMENT=production
# CLOUDFLARE_DATABASE_ID_PRODUCTION=
