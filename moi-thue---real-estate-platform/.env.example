# --- Frontend (Vite) ---
# Bản production (build + deploy Pages từ máy): sao chép thành .env.production và điền URL thật.
# Public site URL for canonical / Open Graph (production: https://your-domain.com)
VITE_SITE_URL=http://localhost:3000
# API moithue-base: gọi thẳng Wrangler (dev). Bỏ dòng này để dùng /api/v1 + proxy Vite (cùng :3000).
VITE_API_BASE=http://127.0.0.1:8787/api/v1
# Khi không set VITE_API_BASE: Vite proxy /api tới đây (chỉ dev)
VITE_API_PROXY_TARGET=http://127.0.0.1:8787

# --- Nest (server/, tùy chọn) — chỉ /api/health + sitemap/robots; không phục vụ /api/v1 ---
# Chạy cùng Vite: npm run dev:stack (mặc định npm run dev chỉ React :3000)
PORT=3333
# Same as VITE_SITE_URL in production: URL users open in the browser (for sitemap loc URLs)
SITE_URL=http://localhost:3000
# Comma-separated origins allowed to call the API (CORS)
WEB_ORIGIN=http://localhost:3000
